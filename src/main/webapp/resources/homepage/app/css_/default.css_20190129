/* 접속기록안내 */
#memberInfo{position:absolute;width:22%;left:98%;top:20%;background:#fff;margin-left:-25%;box-shadow:0px 1px 7px 0px rgba(0,0,0,0.5);z-index: 9;}
#memberInfo .inbox{position:relative;border:1px solid #ccc;padding:10px;}
#memberInfo .inbox dt{font-weight:bold;font-family:verdana;padding-bottom: 10px;}
#memberInfo .inbox dd{padding:3px 0}
a#closeMemberInfo{position:absolute;right:7px;top:5px;font-size:120%}
#line{width: 160px;}
div.loginInfo{padding-top: 8px;padding-bottom: 15px;}
span.fontRed{color: red;}
span.fontBlue{color: rgb(27,104,199);font-weight: bold;}
div.memberCon{background-color: rgb(240,240,240);border-radius: 1em;}
div.memberCon2{padding-top: 12px;padding-left: 10px;padding-right: 10px; padding-bottom: 28px;}
a.btnStyle{float: right;margin-top: 6px;}
#loginIcon{padding-top: 13px;padding-left:10px;}
.boxnImg{ float: left; }
.box2_1 { float: left; width: 34%; }
.box3_1 { float: left; width: 38%; border-left: 1px solid #ddd; }
.boxn { padding-top: 1%; padding-bottom: 1%; padding-left: 5%; }

/*서브페이지 공유버튼*/
div#shareBtnArea{position: fixed;}
div.doc-head{margin-top: -22px;}
div.lnb{margin-top: -22px;}


@media screen and (min-width:1020px){
	.main .qmenu{white-space:nowrap}
}
@media all and (max-width:1020px){
	.main .qmenu .section{width:auto}

	.news-photo .tit{padding-bottom:10px}
	.news-photo .tit,
	.news-photo .photo-list{width:100%;float:none}
	.news-photo .photo-list ul{margin:0}
	.news-photo h3{padding-bottom:5px;margin-bottom:5px;font-size:30px}
	.news-photo h3 span{display:inline}
}
@media all and (max-width:950px){
	.main .qmenu .bx-wrapper{width:auto!important;margin:0 40px!important}
	.main .qmenu .bx-controls{display:block}
	.main2 .tit_bar{height:2px;overflow:hidden;padding:0}
	.main2 .tit_bar li{font-size:0;line-height:0}
	.main2 h3{display:block;font-size:150%;clear:both;padding:0 0 5px}
	.main2 .section > div,
	.main2 .qlink ul,
	.main2 .popupzone ul,
	.main2 .section > div.calendar{height:auto}
	.main .calendar #planBox{padding-bottom:18px}
	.main2 .popupzone h3{margin-left:10px;display:none}
	.main .calendar h3{padding-top:0;margin-top:5px;padding-bottom:10px;font-weight:normal}
	.main2 .section>div.popupzone,
	.main2 .section>div.calendar{width:50%}
	.main2 .section>div.calendar .box,
	.main2 .section>div.qlink .box{margin:0}
	.main2 .section>div.qlink{float:none;width:100%;margin-bottom:20px}
	.main2 .section>div.qlink ul{overflow:hidden;border:1px solid #c1d1e6;border-bottom:0}
	.main2 .section>div.qlink li{float:left;width:50%}
	.main2 .section>div.qlink li a{font-size:15px}
}
@media all and (max-width:900px){
	#main-spot .notice{display:none}
	#main-spot .bx-controls .bx-prev, #main-spot .bx-controls .bx-next{margin-top:-156px}
	.main-img{width:100%}
	.main-img,
	.main-img .bx-wrapper{height:auto!important}
	.section{margin:0 15px}
}
@media all and (max-width:767px){
	.main1 .news{width:100%;float:none;padding-bottom:15px}
	.main2{margin-bottom:20px}
	.main2 .section>div.calendar{margin-bottom:20px}
	.main2 .section>div.popupzone,
	.main2 .section>div.calendar,
	.main2 .section>div.qlink li{float:none;width:100%}
	.main2 .popupzone h3,
	.main2 .popupzone .box{margin-left:0}
}
@media all and (max-width:650px){
	.photo-list li{width:100%}
	.photo-list li.pl3{display:none}
	.photo-list li span.snipet{display:none}
	.news-photo .more{margin-top:15px}
}