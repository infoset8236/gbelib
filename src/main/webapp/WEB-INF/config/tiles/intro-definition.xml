<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE tiles-definitions PUBLIC "-//Apache Software Foundation//DTD Tiles Configuration 2.1//EN" "http://tiles.apache.org/dtds/tiles-config_2_1.dtd">

<tiles-definitions>
	<definition name="/intro/*/*/*/*_ajax" templateExpression="/WEB-INF/views/app/intro/{1}/{2}/{3}/{4}.jsp" />
	<definition name="/intro/*/*/*_ajax" templateExpression="/WEB-INF/views/app/intro/{1}/{2}/{3}.jsp" />
	<definition name="/intro/*/*_ajax" templateExpression="/WEB-INF/views/app/intro/{1}/{2}.jsp" />

	<definition name="introLayout" templateExpression="/WEB-INF/views/app/intro/layout/layout.jsp">
		<put-attribute name="header" expression="/WEB-INF/views/app/intro/layout/header.jsp" />
  		<put-attribute name="footer" expression="/WEB-INF/views/app/intro/layout/footer.jsp" />
	</definition>
	
	<definition name="subLayout" templateExpression="/WEB-INF/views/app/intro/layout/sub.jsp">
		<put-attribute name="header" expression="/WEB-INF/views/app/intro/layout/header.jsp" />
  		<put-attribute name="footer" expression="/WEB-INF/views/app/intro/layout/footer.jsp" />
	</definition>
	
	<definition name="/intro/*/*/*/*" extends="subLayout">
 		<put-attribute name="body" expression="/WEB-INF/views/app/intro/{1}/{2}/{3}/{4}.jsp"></put-attribute>
	</definition>
	
	<definition name="/intro/*/*/*" extends="subLayout">
 		<put-attribute name="body" expression="/WEB-INF/views/app/intro/{1}/{2}/{3}.jsp"></put-attribute>
	</definition>
	
	<definition name="/intro/*/*" extends="subLayout">
 		<put-attribute name="body" expression="/WEB-INF/views/app/intro/{1}/{2}.jsp"></put-attribute>
	</definition>
	
	<definition name="/intro/*" extends="introLayout">
 		<put-attribute name="body" expression="/WEB-INF/views/app/intro/{1}.jsp"></put-attribute>
	</definition>
	
</tiles-definitions>